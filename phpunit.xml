<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>

    <php>
        <env name="APP_ENV"           value="testing"/>
        <env name="APP_KEY"           value="base64:testingtestingtestingtestingtestingtesting="/>
        <env name="APP_DEBUG"         value="true"/>
        <!-- <server> + force : dans le conteneur Docker, APP_ENV/DB_* existent comme
             vraies variables d'environnement, donc présentes dans $_SERVER — que
             Laravel lit en priorité. <env force> ne met à jour que $_ENV/getenv,
             et les tests (RefreshDatabase) s'exécutaient alors sur la base de DEV
             et la vidaient à chaque run. -->
        <server name="APP_ENV"        value="testing"    force="true"/>
        <server name="DB_CONNECTION"  value="pgsql"      force="true"/>
        <server name="DB_HOST"        value="postgres"   force="true"/>
        <server name="DB_PORT"        value="5432"       force="true"/>
        <server name="DB_DATABASE"    value="qayed_test" force="true"/>
        <server name="DB_USERNAME"    value="qayed"      force="true"/>
        <server name="DB_PASSWORD"    value="secret"     force="true"/>
        <env name="DB_CONNECTION"     value="pgsql"      force="true"/>
        <env name="DB_HOST"           value="postgres"   force="true"/>
        <env name="DB_PORT"           value="5432"       force="true"/>
        <env name="DB_DATABASE"       value="qayed_test" force="true"/>
        <env name="DB_USERNAME"       value="qayed"      force="true"/>
        <env name="DB_PASSWORD"       value="secret"     force="true"/>
        <env name="CACHE_STORE"       value="array"/>
        <env name="SESSION_DRIVER"    value="array"/>
        <env name="QUEUE_CONNECTION"  value="sync"/>
        <env name="MAIL_MAILER"       value="array"/>
        <env name="BCRYPT_ROUNDS"     value="4"/>
        <!-- Sanctum -->
        <env name="SANCTUM_STATEFUL_DOMAINS" value="localhost"/>
    </php>
</phpunit>

