APP_NAME=Qayed
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Tunis

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=qayed
DB_USERNAME=qayed
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@qayed.tn"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:3000

# OCR Service (Phase 2: replace with real service)
OCR_DRIVER=mock
OCR_SERVICE_URL=
OCR_SERVICE_KEY=

# File Storage
PASSPORT_SCAN_DISK=local
PASSPORT_SCAN_ENCRYPTION=true

# ─── MODULE PROVISOIRE — Relais WhatsApp check-in (à retirer après homologation MI) ──
# Voir PROMPT-CLAUDE-CODE-QAYED-AUTORITE.md et whatsapp-service/README.md
# À false : module totalement inerte (aucun enfilage, aucun worker, aucune erreur).
WHATSAPP_POLICE_ENABLED=false
# Destinataire unique, format whatsapp-web.js (jamais en dur dans le code).
WHATSAPP_RECIPIENT=216XXXXXXXX@c.us
# Secret partagé avec le service Node (whatsapp-service/) — long et aléatoire.
WHATSAPP_WORKER_SECRET=

# ─── Tracking des coûts IA (Claude vision) ─────────────────────────────────────
# Secret partagé avec la fonction serverless Vercel (scan CIN / repli passeport)
# pour l'ingestion sur POST /internal/ai-usage — long et aléatoire, même valeur
# que INTERNAL_AI_TRACKING_SECRET côté Vercel. Vide => ingestion refusée (401).
INTERNAL_AI_TRACKING_SECRET=
# Modèle Claude utilisé (aligné sur CIN_SCAN_MODEL côté Vercel) — sert au seed du tarif.
CIN_SCAN_MODEL=claude-sonnet-5

# Subscription grace period (days)
SUBSCRIPTION_GRACE_DAYS=3

# ─── Flouci Payment Gateway (Tunisia) ──────────────────────────────────────────
# Obtain from: https://dashboard.flouci.com → Settings → API Keys
FLOUCI_APP_TOKEN=
FLOUCI_APP_SECRET=
FLOUCI_BASE_URL=https://developers.flouci.com/api
# Frontend redirect URLs after payment (Flouci redirects with ?payment_id=xxx)
FLOUCI_SUCCESS_URL=
FLOUCI_FAIL_URL=
# Session timeout in seconds (default 900 = 15 min)
FLOUCI_SESSION_TIMEOUT=900
