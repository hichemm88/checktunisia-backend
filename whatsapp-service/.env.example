# MODULE PROVISOIRE — relais WhatsApp check-in (à retirer après homologation MI).

# Backend Laravel (préfixe API inclus)
LARAVEL_API_BASE=https://checktunisia-backend-production.up.railway.app/api/v1

# Secret partagé — DOIT être identique à WHATSAPP_WORKER_SECRET côté Laravel.
WHATSAPP_WORKER_SECRET=change-me-long-random-secret

# Persistance de la session (survit aux redémarrages sans re-scan du QR).
# En conteneur Railway/Docker : pointer vers un VOLUME PERSISTANT, sinon le QR
# devra être re-scanné à chaque redéploiement (disque éphémère).
WHATSAPP_SESSION_PATH=./.wwebjs_auth

# Port du endpoint santé local du service Node.
PORT=3001

# Cadence de polling à vide (ms) et backoff en cas d'erreur réseau (ms).
WHATSAPP_IDLE_POLL_MS=5000
WHATSAPP_ERROR_BACKOFF_MS=15000

# Chromium fourni par l'image (optionnel — sinon puppeteer télécharge le sien).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
